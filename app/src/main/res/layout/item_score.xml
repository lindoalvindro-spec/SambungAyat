<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="#DDDDDD"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Trophy Badge -->
        <TextView
            android:id="@+id/tvItemBadge"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/shape_circle_emerald_light"
            android:gravity="center"
            android:text="🏆"
            android:textSize="18sp"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvItemSuraLimit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semua Juz 30"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvItemDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kamis, 21 Mei 2026"
                android:textColor="@android:color/darker_gray"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Score point badge -->
        <TextView
            android:id="@+id/tvItemScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="80 Pts"
            android:textColor="@color/emerald_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
